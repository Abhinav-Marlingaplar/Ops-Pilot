# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: single connection string (Neon / Supabase / Render Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Option B: individual vars (local docker-compose)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=cicd_user
# DB_PASSWORD=cicd_pass
# DB_NAME=cicd_db

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://localhost

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_generate_a_real_secret

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WORKER_JWT=change_me_worker_static_token

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_COOKIE_SECRET=change_me_cookie_secret

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Local:  http://localhost:3000/auth/github/callback
# Prod:   https://your-app.onrender.com/auth/github/callback
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# ── Frontend ──────────────────────────────────────────────────────────────────
# Local:  http://localhost:5173
# Prod:   https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173